<?xml version="1.0" encoding="utf-8"?>
<!--
    Floating Manual Calculator
    Root = FrameLayout so the resize handle can be pinned to the bottom-right corner.
    Inner LinearLayout carries the actual content + rounded background.
    Initial size: 300 × 415 dp (set in FloatingWindowService buildParams).
    The GridLayout fills remaining space with layout_weight="1" so all rows
    scale proportionally when the user resizes the window.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── Content card ── -->
    <LinearLayout
        android:id="@+id/manualFloatContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_float_window"
        android:clipToOutline="true"
        android:layout_marginLeft="2dp"
        android:layout_marginRight="2dp"
        android:layout_marginBottom="2dp">

        <!-- ── Drag / Title bar ── -->
        <LinearLayout
            android:id="@+id/floatManualHeader"
            android:layout_width="match_parent"
            android:layout_height="33dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:background="@color/bg_float_header">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Calculator"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"/>

            <ImageButton
                android:id="@+id/btnFloatMinimize"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_minimize"
                android:background="@drawable/bg_icon_btn"
                android:contentDescription="Minimize"
                android:padding="6dp"/>

            <Space android:layout_width="2dp" android:layout_height="1dp"/>

            <ImageButton
                android:id="@+id/btnFloatClose"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_close"
                android:background="@drawable/bg_icon_btn"
                android:contentDescription="Close"
                android:padding="6dp"/>
        </LinearLayout>

        <!-- ── Display ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.5"
            android:orientation="vertical"
            android:gravity="bottom|end"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="0dp">

            <HorizontalScrollView
                android:id="@+id/svFloatExpression"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="3.5"
                android:fillViewport="true"
                android:scrollbars="none"
                android:overScrollMode="never">

                <TextView
                    android:id="@+id/tvFloatExpression"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:textColor="@color/text_secondary"
                    android:gravity="end|bottom"
                    android:singleLine="true"
                    android:fontFamily="sans-serif-light"
                    android:textSize="18sp"/>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvFloatResult"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="6.5"
                android:text="0"
                android:textColor="@color/text_primary"
                android:gravity="end|bottom"
                android:singleLine="true"
                android:ellipsize="start"
                android:fontFamily="sans-serif-light"
                android:includeFontPadding="false"
                android:autoSizeTextType="uniform"
                app:autoSizeTextType="uniform"
                android:autoSizeMinTextSize="12sp"
                android:autoSizeMaxTextSize="44sp"
                app:autoSizeMinTextSize="12sp"
                app:autoSizeMaxTextSize="44sp"
                android:autoSizeStepGranularity="1sp"
                app:autoSizeStepGranularity="1sp"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"/>

        <!-- ── Button Grid – fills remaining space so buttons scale on resize ── -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3.5"
            android:columnCount="4"
            android:rowCount="4"
            android:padding="1dp"
            android:layout_marginLeft="2dp"
            android:layout_marginRight="2dp"
            android:layout_marginBottom="2dp"
            android:useDefaultMargins="false">

            <!-- Row 1: 7  8  9  × -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloat7"
                style="@style/CalcFloatButtonNumber"
                android:text="7"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloat8"
                style="@style/CalcFloatButtonNumber"
                android:text="8"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloat9"
                style="@style/CalcFloatButtonNumber"
                android:text="9"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloatMultiply"
                style="@style/CalcFloatButtonOperator"
                android:text="×"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

            <!-- Row 2: 4  5  6  − -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloat4"
                style="@style/CalcFloatButtonNumber"
                android:text="4"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloat5"
                style="@style/CalcFloatButtonNumber"
                android:text="5"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloat6"
                style="@style/CalcFloatButtonNumber"
                android:text="6"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloatSubtract"
                style="@style/CalcFloatButtonOperator"
                android:text="−"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

            <!-- Row 3: 1  2  3  + -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloat1"
                style="@style/CalcFloatButtonNumber"
                android:text="1"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloat2"
                style="@style/CalcFloatButtonNumber"
                android:text="2"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloat3"
                style="@style/CalcFloatButtonNumber"
                android:text="3"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloatAdd"
                style="@style/CalcFloatButtonOperator"
                android:text="+"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

            <!-- Row 4: AC  0  ⌫  = -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloatClear"
                style="@style/CalcFloatButtonFunction"
                android:text="AC"
                android:textAllCaps="false"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloat0"
                style="@style/CalcFloatButtonNumber"
                android:text="0"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloatBackspace"
                style="@style/CalcFloatButtonFunction"
                android:text="⌫"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFloatEquals"
                style="@style/CalcFloatButtonEquals"
                android:text="="
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_width="0dp"
                android:layout_height="0dp"/>

        </GridLayout>

    </LinearLayout>

    <!-- Bottom-right invisible resize handle -->
    <View
        android:id="@+id/resizeRight"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_gravity="bottom|end"
        android:clickable="true"
        android:focusable="true" />

    <!-- Bottom-left invisible resize handle -->
    <View
        android:id="@+id/resizeLeft"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_gravity="bottom|start"
        android:clickable="true"
        android:focusable="true" />

</FrameLayout>
