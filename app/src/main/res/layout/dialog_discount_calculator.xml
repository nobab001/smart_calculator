<?xml version="1.0" encoding="utf-8"?>
<!--
    Quick Discount Calculator Dialog
    ┌──────────────────────────────────┐
    │  🏷 Quick Discount          [X]  │
    │                                  │
    │  Total Amount                    │
    │  [________________________]      │
    │                                  │
    │  Discount                        │
    │  [_______________________] %     │
    │                                  │
    │ ┌──── Result ────────────────┐   │
    │ │  Final Price       1,700   │   │
    │ │  You save            300   │   │
    │ │               [📋 Copy]    │   │
    │ └────────────────────────────┘   │
    └──────────────────────────────────┘
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_settings_card"
    android:padding="24dp">

    <!-- ── Header ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Quick Discount"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"/>

        <ImageButton
            android:id="@+id/btnDiscountClose"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:contentDescription="Close"
            android:padding="6dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="20dp"
        android:background="@color/divider"/>

    <!-- ── Total Amount field ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total Amount"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.05"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_discount_result"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etTotalAmount"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="0"
            android:textColorHint="@color/text_secondary"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:fontFamily="sans-serif-light"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:imeOptions="actionNext"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="৳"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <!-- ── Second field: Save (default) / Discount (after toggle) ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvModeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"/>

        <ImageButton
            android:id="@+id/btnSwapMode"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_swap_mode"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:contentDescription="Toggle Save / Discount mode"
            android:padding="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_discount_result"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etDiscountPercent"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="0"
            android:textColorHint="@color/text_secondary"
            android:inputType="numberDecimal"
            android:textColor="@color/btn_operator"
            android:textSize="20sp"
            android:fontFamily="sans-serif-light"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:imeOptions="actionDone"/>

        <TextView
            android:id="@+id/tvModeSuffix"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="৳"
            android:textColor="@color/btn_operator"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <!-- ── Result card ── -->
    <LinearLayout
        android:id="@+id/cardResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_discount_result"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <!-- Final Price row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Final Price"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvFinalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/btn_equals"
                android:textSize="26sp"
                android:fontFamily="sans-serif-light"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="@color/divider"/>

        <!-- You save row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvSecondaryResultLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="You save"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvSavedAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/btn_operator"
                android:textSize="18sp"
                android:fontFamily="sans-serif-light"/>
        </LinearLayout>

        <!-- Copy button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnCopyResult"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Copy Result"
                android:textColor="#FFFFFFFF"
                android:backgroundTint="@color/btn_action"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="20dp"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
