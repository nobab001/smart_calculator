<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- ── Header ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- ── APPEARANCE section ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="APPEARANCE"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:letterSpacing="0.12"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="10dp"/>

    <!-- Theme selection: 3 cards side-by-side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:weightSum="3">

        <!-- Light card -->
        <LinearLayout
            android:id="@+id/cardLight"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_theme_unselected"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iconLight"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_light_mode"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/labelLight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Light"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="6dp"/>

            <View
                android:id="@+id/dotLight"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_bubble"
                android:visibility="invisible"/>
        </LinearLayout>

        <!-- Dark card -->
        <LinearLayout
            android:id="@+id/cardDark"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="3dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_theme_unselected"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iconDark"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_dark_mode"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/labelDark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dark"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="6dp"/>

            <View
                android:id="@+id/dotDark"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_bubble"
                android:visibility="invisible"/>
        </LinearLayout>

        <!-- System/Auto card -->
        <LinearLayout
            android:id="@+id/cardSystem"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_theme_unselected"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iconSystem"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_auto_mode"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/labelSystem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="System"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="6dp"/>

            <View
                android:id="@+id/dotSystem"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_bubble"
                android:visibility="invisible"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Description of selected mode -->
    <TextView
        android:id="@+id/tvThemeDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:gravity="center"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp"/>

    <!-- ── FLOATING WINDOWS section ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="FLOATING WINDOWS"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:letterSpacing="0.12"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="10dp"/>

    <!-- Manual popup theme row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Manual window"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"/>

        <!-- Light toggle for Manual -->
        <LinearLayout
            android:id="@+id/manualThemeLight"
            android:layout_width="72dp"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_theme_selected"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Light"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Dark toggle for Manual -->
        <LinearLayout
            android:id="@+id/manualThemeDark"
            android:layout_width="72dp"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_theme_unselected"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dark"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Smart popup theme row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Smart window"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"/>

        <!-- Light toggle for Smart -->
        <LinearLayout
            android:id="@+id/smartThemeLight"
            android:layout_width="72dp"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_theme_selected"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Light"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <!-- Dark toggle for Smart -->
        <LinearLayout
            android:id="@+id/smartThemeDark"
            android:layout_width="72dp"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_theme_unselected"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dark"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:background="@color/divider"/>

    <!-- ── LAYOUT section ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BUTTON LAYOUT"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:letterSpacing="0.12"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="10dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_settings_card"
        android:layout_marginHorizontal="16dp"
        android:paddingBottom="4dp">

        <!-- Move Buttons row -->
        <LinearLayout
            android:id="@+id/rowMoveButtons"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_move_buttons"
                android:tint="@color/text_primary"
                android:layout_marginEnd="14dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Move Buttons"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drag to rearrange calculator keys"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_arrow_back"
                android:rotation="180"
                android:tint="@color/text_secondary"
                android:alpha="0.5"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.8dp"
            android:layout_marginHorizontal="20dp"
            android:background="@color/divider"/>

        <!-- Reset Layout row -->
        <LinearLayout
            android:id="@+id/rowResetLayout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_delete_history"
                android:tint="@color/btn_operator"
                android:layout_marginEnd="14dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reset Layout"
                    android:textColor="@color/btn_operator"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Restore default OnePlus-style order"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider before About -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="24dp"
        android:background="@color/divider"/>

    <!-- ── ABOUT section ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ABOUT"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:letterSpacing="0.12"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="10dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_settings_card"
        android:layout_marginHorizontal="16dp"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Smart Calculator"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Version 1.0  •  WhatsApp Smart Integration"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- ── DEVELOPED BY section ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DEVELOPED BY"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:letterSpacing="0.12"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="10dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_settings_card"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp">

        <!-- Header row: name + arrow toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp">

            <TextView
                android:id="@+id/tvDeveloperName"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="MD Yousuf"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"/>

            <ImageButton
                android:id="@+id/btnDeveloperExpand"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_arrow_back"
                android:rotation="180"
                android:tint="@color/text_secondary"
                android:alpha="0.7"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Show developer contacts"
                android:padding="8dp"/>
        </LinearLayout>

        <!-- Contact panel (hidden by default) -->
        <LinearLayout
            android:id="@+id/panelDeveloperContacts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingHorizontal="20dp"
            android:paddingBottom="14dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="0.8dp"
                android:background="@color/divider"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:id="@+id/rowDevCall"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Call:"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01614677619"
                    android:textColor="@color/btn_action"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rowDevWhatsApp"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp:"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01894086541"
                    android:textColor="@color/btn_equals"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
</ScrollView>
