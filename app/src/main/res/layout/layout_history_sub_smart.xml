<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutHistoryPanel"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_float_window"
    android:elevation="8dp">

    <!-- Header bar with "HISTORY" and Close Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="12dp"
        android:paddingRight="8dp"
        android:background="@color/bg_float_header">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="HISTORY"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-medium"/>

        <ImageButton
            android:id="@+id/btnSubHistoryClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_icon_btn"
            android:contentDescription="Close"
            android:padding="5dp"
            android:alpha="0.75"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- Scrollable container for history items -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:scrollbars="vertical">
        <LinearLayout
            android:id="@+id/layoutHistoryItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="4dp"/>
    </ScrollView>

    <!-- Divider before total -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="2dp"
        android:background="@color/btn_operator"/>

    <TextView
        android:id="@+id/tvHistoryTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total: 0"
        android:textColor="@color/btn_operator"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="end"
        android:paddingHorizontal="12dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"/>

    <!-- Clear session button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClearHistory"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="6dp"
        android:text="Clear Session"
        android:textSize="12sp"
        android:textColor="@color/text_primary"
        app:backgroundTint="@color/btn_function"
        app:cornerRadius="10dp"
        android:stateListAnimator="@null"
        android:elevation="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"/>
</LinearLayout>
