<?xml version="1.0" encoding="utf-8"?>
<!--
    Smart Mode Floating Window ~210 × 220dp
    Root = FrameLayout to allow resizing handles in bottom corners.
    Inner LinearLayout = content card.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/smartFloatContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_float_window"
        android:clipToOutline="true">

        <!-- ── Title bar (drag handle) ── -->
        <LinearLayout
            android:id="@+id/smartHeader"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:background="@color/bg_float_header">

            <!-- History button on the LEFT of title -->
            <ImageButton
                android:id="@+id/btnSmartHistory"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_history"
                android:background="@drawable/bg_icon_btn"
                android:contentDescription="History"
                android:padding="5dp"
                android:alpha="0.75"/>

            <Space android:layout_width="4dp" android:layout_height="1dp"/>

            <TextView
                android:id="@+id/tvSmartTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Smart Calc"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:gravity="center"
                android:fontFamily="sans-serif-medium"/>

            <ImageButton
                android:id="@+id/btnSmartMinimize"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_minimize"
                android:background="@drawable/bg_icon_btn"
                android:contentDescription="Minimize"
                android:padding="7dp"/>

            <Space android:layout_width="4dp" android:layout_height="1dp"/>

            <ImageButton
                android:id="@+id/btnSmartClose"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_close"
                android:background="@drawable/bg_icon_btn"
                android:contentDescription="Close"
                android:clickable="true"
                android:focusable="true"
                android:padding="7dp"/>
        </LinearLayout>

        <!-- ── Expression + Total display ── -->
        <LinearLayout
            android:id="@+id/smartDisplayArea"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="2dp">

            <!-- Expression row: scrollable history tokens + overlay editor -->
            <FrameLayout
                android:id="@+id/smartExpressionArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:layout_marginHorizontal="3dp"
                android:minHeight="28dp">

                <HorizontalScrollView
                    android:id="@+id/scrollSmartExpression"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:overScrollMode="never"
                    android:clickable="true"
                    android:focusable="false">

                    <LinearLayout
                        android:id="@+id/layoutSmartExpressionItems"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="2dp"/>
                </HorizontalScrollView>

                <com.example.smartcalculator.SmartExpressionEditText
                    android:id="@+id/etSmartExpression"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:background="@null"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-light"
                    android:inputType="text"
                    android:digits="0123456789+-*/."
                    android:singleLine="true"
                    android:gravity="center"
                    android:imeOptions="actionDone"
                    android:padding="2dp"/>
            </FrameLayout>

            <!-- TOTAL label -->
            <TextView
                android:id="@+id/tvSmartLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TOTAL"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:gravity="center"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp"/>

            <!-- Large total row: dimmed "=" on left + number -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp">

                <!-- Large total number -->
                <TextView
                    android:id="@+id/tvSmartTotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_primary"
                    android:textSize="30sp"
                    android:gravity="center"
                    android:singleLine="true"
                    android:ellipsize="start"
                    android:fontFamily="sans-serif-light"
                    android:includeFontPadding="false"/>

                <!-- Dimmed "=" sign, far left, clickable to toggle badge -->
                <TextView
                    android:id="@+id/tvSmartEquals"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="="
                    android:textColor="@color/text_primary"
                    android:alpha="0.25"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-light"
                    android:includeFontPadding="false"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="8dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </RelativeLayout>

            <!-- Item count / equals badge row -->
            <TextView
                android:id="@+id/tvSmartCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="0dp"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"/>

        <!-- ── Action buttons row ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">

            <!-- Undo Last Selection -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSmartUndo"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Undo"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                app:backgroundTint="@color/btn_function"
                app:cornerRadius="12dp"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <!-- Copy Result -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSmartAction"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Copy"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                app:backgroundTint="@color/btn_action"
                app:cornerRadius="12dp"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Bottom-right resize handle — invisible but touch-active -->
    <View
        android:id="@+id/smartResizeRight"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="bottom|end"
        android:contentDescription="Resize Right"
        android:clickable="true"
        android:focusable="true"/>

    <!-- Bottom-left resize handle — invisible but touch-active -->
    <View
        android:id="@+id/smartResizeLeft"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="bottom|start"
        android:contentDescription="Resize Left"
        android:clickable="true"
        android:focusable="true"/>

</FrameLayout>
